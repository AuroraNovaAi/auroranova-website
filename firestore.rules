rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/web_users/$(request.auth.uid)).data.roles.hasAny(['admin']);
    }

    // Kullanıcılar — auth gerektiriyor
    match /web_users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow update: if isAdmin();
    }

    // Ürünler — herkese açık okuma, admin yazar
    match /products/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // İletişim başvuruları — herkes gönderebilir, admin yönetir
    match /contactSubmissions/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Site ayarları — herkese açık okuma, admin yazar
    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Sayfa görüntülemeleri — herkes yazar, admin okur
    match /pageViews/{docId} {
      allow read: if isAdmin();
      allow write: if true;
    }

    // Blog yazıları — herkese açık okuma, admin yazar
    match /blog_posts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Galeri kartları — herkese açık okuma, admin yazar
    match /gallery_items/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Site içeriği (CMS metinleri) — herkese açık okuma, admin yazar
    match /site_content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Finance verisi
    match /fin_data/{docId} {
      allow read, write: if request.auth != null;
    }

    // Finance erişim listesi
    match /fin_settings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.email == 'inanc.eser@auroranovaai.com';
    }

    // Diğer her şey kapalı
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
